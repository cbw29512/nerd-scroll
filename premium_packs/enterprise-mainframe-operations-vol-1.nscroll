======================================================================
SESSION 0011 :: REXX OPS HELPER
======================================================================

/* REXX */
parse upper arg jobprefix
if jobprefix = '' then jobprefix = 'PAY'
say 'NERD SCROLL REXX OPS HELPER'
say 'SCANNING JOB PREFIX:' jobprefix
address TSO
"PROFILE MSGID"
"LISTDS 'PROD.PAYROLL.MASTER' STATUS"
if rc <> 0 then do
  say 'DATASET STATUS CHECK RETURN CODE:' rc
end
else do
  say 'DATASET STATUS CHECK COMPLETE'
end
say 'SUBMITTING VISUAL REPORT ONLY'
exit 0

READY
TSO LISTDS 'PROD.PAYROLL.MASTER' STATUS
DATASET PROD.PAYROLL.MASTER IS IN CATALOG SYS1.MCAT
DATASET STATUS CHECK COMPLETE

