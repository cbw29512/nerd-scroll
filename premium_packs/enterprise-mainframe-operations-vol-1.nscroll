JOB 0013 :: C FOR Z/OS STYLE MODULE
======================================================================

/* Fictional C module displayed for terminal ambience */
#include <stdio.h>
#include <string.h>

#define MAX_REC_LEN 160

int main(void) {
    char record[MAX_REC_LEN + 1];
    long count = 0;

    while (fgets(record, sizeof(record), stdin) != NULL) {
        if (strncmp(record, "HDR", 3) == 0) {
            printf("HEADER RECORD ACCEPTED\n");
        }
        count++;
    }

    printf("RECORDS PROCESSED: %ld\n", count);
    return 0;
}

